{
  "name": "lacus/cnpj-fmt",
  "type": "library",
  "description": "Utility to format CNPJ (Brazilian Business Tax ID)",
  "license": "MIT",
  "authors": [
    {
      "name": "Julio L. Muller",
      "email": "juliolmuller@outlook.com",
      "homepage": "https://juliolmuller.github.io"
    }
  ],
  "keywords": [
    "cnpj",
    "format",
    "formatting",
    "formatar",
    "mascara",
    "mask",
    "pt-br",
    "br"
  ],
  "support": {
    "issues": "https://github.com/LacusSolutions/br-utils-php/issues",
    "source": "https://github.com/LacusSolutions/br-utils-php"
  },
  "homepage": "https://cnpj-utils.vercel.app/",
  "scripts": {
    "lint": [
      "@lint:format",
      "@lint:check"
    ],
    "lint:ci": [
      "@lint:format --dry-run",
      "@lint:check --dry-run"
    ],
    "lint:format": "@php ../../run lint:format cnpj-fmt",
    "lint:check": "@php ../../run lint:check cnpj-fmt",
    "test": "pest --configuration=.pest.config.xml",
    "test:watch": "@test --watch",
    "test:cov": "@test --coverage-html coverage"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "require": {
    "php": "^8.2",
    "lacus/utils": "^1.0"
  },
  "require-dev": {
    "pestphp/pest": "^3.8"
  },
  "autoload": {
    "psr-4": {
      "Lacus\\BrUtils\\Cnpj\\": "src/"
    },
    "files": [
      "src/cnpj-fmt.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Lacus\\BrUtils\\Tests\\Cnpj\\": "tests/specs/"
    }
  }
}
