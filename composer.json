{
  "name": "lacus/monorepo",
  "type": "project",
  "description": "Monorepo for Lacus BR Utils for PHP",
  "license": "MIT",
  "authors": [
    {
      "name": "Julio L. Muller",
      "email": "juliolmuller@outlook.com",
      "homepage": "https://juliolmuller.github.io"
    }
  ],
  "scripts": {
    "prepare": "captainhook install --no-interaction --configuration=.captainhook.config.json",
    "commit": "conventional-commits prepare",
    "release": "@php run release",
    "lint": "@php run lint",
    "lint:ci": "@php run lint:ci",
    "lint:format": "@php run lint:format",
    "lint:check": "@php run lint:check",
    "test:cnpj-fmt": "cd packages/cnpj-fmt && composer test",
    "test:cnpj-gen": "cd packages/cnpj-gen && composer test",
    "test:cnpj-val": "cd packages/cnpj-val && composer test",
    "test:cnpj-utils": "cd packages/cnpj-utils && composer test",
    "test:cpf-fmt": "cd packages/cpf-fmt && composer test",
    "test:cpf-gen": "cd packages/cpf-gen && composer test",
    "test:cpf-val": "cd packages/cpf-val && composer test",
    "test:cpf-utils": "cd packages/cpf-utils && composer test",
    "test:br-utils": "cd packages/br-utils && composer test",
    "test:formatters": [
      "@test:cnpj-fmt",
      "@test:cpf-fmt"
    ],
    "test:generators": [
      "@test:cpf-gen",
      "@test:cnpj-gen"
    ],
    "test:validators": [
      "@test:cpf-val",
      "@test:cnpj-val"
    ],
    "test:utils": [
      "@test:cnpj-utils",
      "@test:cpf-utils",
      "@test:br-utils"
    ],
    "test:cnpj": [
      "@test:cnpj-fmt",
      "@test:cnpj-gen",
      "@test:cnpj-val",
      "@test:cnpj-utils"
    ],
    "test:cpf": [
      "@test:cpf-val",
      "@test:cpf-gen",
      "@test:cpf-fmt",
      "@test:cpf-utils"
    ],
    "test:all": [
      "@test:formatters",
      "@test:generators",
      "@test:validators",
      "@test:utils"
    ]
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "captainhook/hook-installer": true,
      "infection/extension-installer": false
    }
  },
  "extra": {
    "captainhook": {
      "config": ".captainhook.config.json"
    }
  },
  "require": {
    "php": ">=8.2"
  },
  "require-dev": {
    "captainhook/captainhook": "^5.29",
    "captainhook/hook-installer": "^1.0",
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpstan/phpstan": "^2.1",
    "ramsey/conventional-commits": "^1.7",
    "roave/security-advisories": "dev-latest",
    "symfony/console": "^7.4",
    "symfony/filesystem": "^7.4",
    "symfony/process": "^7.4"
  },
  "autoload-dev": {
    "psr-4": {
      "Scripts\\": "scripts/"
    }
  }
}
