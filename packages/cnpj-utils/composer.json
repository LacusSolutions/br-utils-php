{
  "name": "lacus/cnpj-utils",
  "type": "library",
  "description": "Utility functions to deal with CNPJ (Brazilian employer ID)",
  "license": "MIT",
  "authors": [
    {
      "name": "Julio L. Muller",
      "email": "juliolmuller@outlook.com",
      "homepage": "https://juliolmuller.github.io"
    }
  ],
  "keywords": [
    "cnpj",
    "validar",
    "validador",
    "validate",
    "validation",
    "formatar",
    "format",
    "gerar",
    "gerador",
    "generate",
    "generator",
    "pt-br",
    "br"
  ],
  "support": {
    "issues": "https://github.com/LacusSolutions/br-utils-php/issues",
    "source": "https://github.com/LacusSolutions/br-utils-php"
  },
  "homepage": "https://cpf-utils.vercel.app/",
  "scripts": {
    "lint": [
      "@lint:format",
      "@lint:check"
    ],
    "lint:ci": [
      "@lint:format --dry-run --diff",
      "@lint:check --no-progress"
    ],
    "lint:format": "php-cs-fixer fix --config=.php-cs-fixer.config.php",
    "lint:check": "phpstan analyse --configuration=.php-stan.config.neon",
    "test": "phpunit",
    "test:watch": "phpunit-watcher watch",
    "test-coverage": "phpunit --coverage-html coverage"
  },
  "config": {
    "sort-packages": true
  },
  "require": {
    "php": ">=8.1",
    "lacus/cnpj-fmt": "^1.0",
    "lacus/cnpj-gen": "^1.0",
    "lacus/cnpj-val": "^1.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^10.5",
    "spatie/phpunit-watcher": "~1.24"
  },
  "autoload": {
    "psr-4": {
      "Lacus\\CnpjUtils\\": "src/"
    },
    "files": [
      "src/cnpj_utils.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Lacus\\CnpjUtils\\Tests\\": "tests/",
      "Lacus\\CnpjFmt\\Tests\\": "vendor/lacus/cnpj-fmt/tests/",
      "Lacus\\CnpjGen\\Tests\\": "vendor/lacus/cnpj-gen/tests/",
      "Lacus\\CnpjVal\\Tests\\": "vendor/lacus/cnpj-val/tests/"
    }
  }
}
