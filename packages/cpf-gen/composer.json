{
  "name": "lacus/cpf-gen",
  "type": "library",
  "description": "Utility function to generate valid CPF (Brazilian personal ID)",
  "license": "MIT",
  "authors": [
    {
      "name": "Julio L. Muller",
      "email": "juliolmuller@outlook.com",
      "homepage": "https://juliolmuller.github.io"
    }
  ],
  "keywords": [
    "cpf",
    "generate",
    "generator",
    "gerador",
    "gerar",
    "faker",
    "fake",
    "pt-br",
    "br"
  ],
  "support": {
    "issues": "https://github.com/LacusSolutions/br-utils-php/issues",
    "source": "https://github.com/LacusSolutions/br-utils-php"
  },
  "homepage": "https://cpf-utils.vercel.app/",
  "scripts": {
    "lint": [
      "@lint:format",
      "@lint:check"
    ],
    "lint:ci": [
      "@lint:format --dry-run --diff",
      "@lint:check --no-progress"
    ],
    "lint:format": "php-cs-fixer fix --config=.php-cs-fixer.config.php",
    "lint:check": "phpstan analyse --configuration=.php-stan.config.neon",
    "test": "phpunit",
    "test:watch": "phpunit-watcher watch",
    "test-coverage": "phpunit --coverage-html coverage"
  },
  "config": {
    "sort-packages": true
  },
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^10.5",
    "spatie/phpunit-watcher": "~1.24"
  },
  "autoload": {
    "psr-4": {
      "Lacus\\CpfGen\\": "src/"
    },
    "files": [
      "src/cpf-gen.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Lacus\\CpfGen\\Tests\\": "tests/"
    }
  }
}
