# Shared PHPStan configuration for all packages. Paths are passed via lint-check.php.
parameters:
  level: 10
  excludePaths:
    - **/vendor/**
  reportUnmatchedIgnoredErrors: false
  treatPhpDocTypesAsCertain: false
  ignoreErrors:
    - paths:
        - **/tests/**/*.spec.php
        - **/tests/*Test.php
      identifiers:
        - argument.type
        - assign.propertyType
        - booleanNot.alwaysFalse
        - booleanNot.alwaysTrue
        - callable.nonCallable
        - method.alreadyNarrowedType
        - varTag.nativeType
